# nprocs: 8

# Test: CuSi7 #
LATVEC_SCALE: 8.8817121463 8.8817121463 8.8817121463
LATVEC:
1 0 0
0 1 0
0 0 1
MESH_SPACING: 0.4
FD_ORDER: 12
BC: P P P
EXCHANGE_CORRELATION: GGA_PBE
TOL_SCF: 1e-6


PRINT_FORCES: 1
PRINT_ATOMS: 1
CALC_STRESS: 1

MD_FLAG: 1                    # 1= MD, 0= no MD (default)
ION_TEMP: 1000
MD_METHOD: NPT_NP
MD_TIMESTEP: 0.6
MD_NSTEP: 1000
RESTART_FLAG: 0
EXTERNAL_PRESSURE: 12 GPa
NPT_NP_QMASS: 115000.0
NPT_NP_BMASS: 71
#NPT_NP_ANGLES: 1
NPT_SCALE_CONSTRAINTS: 123

